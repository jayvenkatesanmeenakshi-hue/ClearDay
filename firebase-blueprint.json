{
  "entities": {
    "Ritual": {
      "title": "Ritual",
      "description": "User's daily ritual data including brain dump, processed tasks, and schedule.",
      "type": "object",
      "properties": {
        "rawText": { "type": "string" },
        "processedTasks": { "type": "string" },
        "todayPlan": { "type": "string" },
        "checklist": { "type": "array" },
        "availableTime": { "type": "string" },
        "energyLevel": { "type": "string" },
        "startTime": { "type": "string" },
        "endTime": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "User": {
      "title": "Ecosystem User",
      "description": "Global user profile shared across StarVortex apps.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "lastLogin": { "type": "string", "format": "date-time" },
        "lastActive": { "type": "string", "format": "date-time" },
        "appsUsed": { "type": "array" },
        "xp": { "type": "number", "default": 0 },
        "level": { "type": "number", "default": 1 },
        "discipline": { "type": "number", "default": 0 },
        "streak": { "type": "number", "default": 0 }
      }
    },
    "Activity": {
      "title": "Ecosystem Activity",
      "description": "A significant action logged to the global stream.",
      "type": "object",
      "properties": {
        "action": { "type": "string", "description": "Format: [APP_NAME]: [DESCRIPTION]" },
        "timestamp": { "type": "string", "format": "date-time" },
        "metadata": { 
          "type": "object",
          "description": "Information for GrindOS XP/Skill calculations."
        }
      }
    }
  },
  "firestore": {
    "/rituals/{userId}": {
      "schema": "Ritual",
      "description": "Collection of user rituals, keyed by user ID."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Shared ecosystem user profiles."
    },
    "/users/{userId}/activities/{activityId}": {
      "schema": "Activity",
      "description": "Global activity stream for XP and record-keeping."
    }
  }
}
