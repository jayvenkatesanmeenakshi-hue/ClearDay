// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: rituals
// Document ID: {userId} (Firebase Auth UID)
// Fields:
//   - rawText: string (optional, < 10000) - The raw brain dump text.
//   - processedTasks: string (optional, < 10000) - The AI-processed and categorized tasks.
//   - todayPlan: string (optional, < 10000) - The generated daily schedule.
//   - checklist: list (optional, < 100) - List of tasks for execution mode.
//   - availableTime: string (optional, < 50) - User's available time for the day.
//   - energyLevel: string (enum: Low, Medium, High) - User's energy level.
//   - startTime: string (optional, HH:MM) - Daily start time.
//   - endTime: string (optional, HH:MM) - Daily end time.
//   - updatedAt: timestamp (required) - Last update timestamp.
//
// Collection: users
// Document ID: {userId}
// Fields:
//   - role: string (admin, user)
//   - email: string
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "jayvenkatesanmeenakshi@gmail.com" && request.auth.token.email_verified == true));
    }

    function isRecent(ts) {
      return ts <= request.time && ts > request.time - duration.value(5, 'm');
    }

    function isValidRitual(data) {
      return data.keys().hasOnly([
        'rawText', 'processedTasks', 'todayPlan', 'checklist', 
        'availableTime', 'energyLevel', 'startTime', 'endTime', 'updatedAt'
      ]) &&
      (!('rawText' in data) || data.rawText is string && data.rawText.size() < 10000) &&
      (!('processedTasks' in data) || data.processedTasks is string && data.processedTasks.size() < 10000) &&
      (!('todayPlan' in data) || data.todayPlan is string && data.todayPlan.size() < 10000) &&
      (!('checklist' in data) || data.checklist is list && data.checklist.size() < 100) &&
      (!('availableTime' in data) || data.availableTime is string && data.availableTime.size() < 50) &&
      (!('energyLevel' in data) || data.energyLevel in ['Low', 'Medium', 'High']) &&
      (!('startTime' in data) || data.startTime is string && data.startTime.matches("^[0-9]{2}:[0-9]{2}$")) &&
      (!('endTime' in data) || data.endTime is string && data.endTime.matches("^[0-9]{2}:[0-9]{2}$")) &&
      data.updatedAt is timestamp && isRecent(data.updatedAt);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && request.resource.data.role == 'user';
      allow update: if isAdmin() || (isOwner(userId) && request.resource.data.role == resource.data.role);
    }

    match /rituals/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidRitual(request.resource.data);
      allow update: if isOwner(userId) && isValidRitual(request.resource.data);
      allow delete: if isOwner(userId) || isAdmin();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
